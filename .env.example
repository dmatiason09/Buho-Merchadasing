# ===================================================================
# BUHO - Variables de entorno
# ===================================================================
# Copia este archivo como .env.local y completa los valores
# .env.local NUNCA se sube al repositorio (está en .gitignore)
# ===================================================================

# -------------------------------------------------------------------
# PUBLIC (accesibles desde el cliente — empiezan con NEXT_PUBLIC_)
# -------------------------------------------------------------------

# URL pública del sitio (usada en metadatos SEO, OpenGraph, sitemap)
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# -------------------------------------------------------------------
# PRIVATE (solo accesibles en el servidor — NUNCA empiezan con NEXT_PUBLIC_)
# -------------------------------------------------------------------

# Endpoint webhook de n8n para recibir leads del formulario de contacto
# (lo configuramos en la fase de automatizaciones)
N8N_CONTACT_WEBHOOK_URL=""

# API Key de Resend para envío de emails (alternativa o complemento a n8n)
# https://resend.com
RESEND_API_KEY=""

# Email donde se reciben los leads del formulario
CONTACT_EMAIL_TO="hola@buho.com"
